# Munesh AI - Environment Variables
# Copy this file to .env and fill in your values

# App Configuration
APP_NAME=Munesh AI
APP_VERSION=1.0.0
DEBUG=true

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///./munesh_ai.db
# DATABASE_URL=postgresql://user:password@localhost:5432/munesh_ai

# Redis (optional, for caching and queues)
REDIS_URL=redis://localhost:6379/0

# WhatsApp Cloud API
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=munesh_ai_verify_token

# LLM Configuration (gemini | openai | claude)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Follow-up Configuration
FOLLOW_UP_DELAY_HOURS=24
MAX_MEMORY_MESSAGES=10
